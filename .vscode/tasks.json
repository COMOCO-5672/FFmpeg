{
    "version": "2.0.0",
    "tasks": [
      {
        "label": "configure",
        "type": "shell",
        "command": "../configure",
        "args": ["--enable-debug"],
        "options": {
          "cwd": "${workspaceFolder}/build",
          "env": {
            "PATH": "D:\\github\\davs2\\install\\bin;D:\\msys64\\mingw64\\bin;D:\\msys64\\usr\\bin;${env:PATH}",
            "MSYSTEM": "MINGW64",
            "CHERE_INVOKING": "1"
          },
          "shell": {
            "executable": "D:\\msys64\\usr\\bin\\bash.exe",
            "args": ["-lc"]
          }
        },
        "group": {
          "kind": "build",
          "isDefault": true
        },
        "problemMatcher": []
      },
      {
        "label": "build",
        "type": "shell",
        "command": "make -j10",
        "options": {
          "cwd": "${workspaceFolder}/build",
          "env": {
            "PATH": "D:\\github\\davs2\\install\\bin;D:\\msys64\\mingw64\\bin;D:\\msys64\\usr\\bin;${env:PATH}",
            "MSYSTEM": "MINGW64",
            "CHERE_INVOKING": "1"
          },
          "shell": {
            "executable": "D:\\msys64\\usr\\bin\\bash.exe",
            "args": ["-lc"]
          }
        },
        "group": {
          "kind": "build",
          "isDefault": true
        },
        "problemMatcher": ["$gcc"]
      }
    ]
  }
  
